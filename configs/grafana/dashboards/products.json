{
  "title": "Products Service",
  "uid": "marketplace-products",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "refresh": 1,
        "current": {},
        "includeAll": false,
        "multi": false,
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Overall RPS & p90 Latency",
      "description": "Левая ось — суммарный RPS. Правая ось — p90 время ответа.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(requests_total{service=\"product\"}[1m]))",
          "legendFormat": "RPS",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.90, sum(rate(request_duration_seconds_bucket{service=\"product\"}[1m])) by (le))",
          "legendFormat": "p90 Latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p90 Latency" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 2,
      "title": "Error Rate by Method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(requests_total{service=\"product\", code!=\"OK\"}[1m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 3,
      "title": "Traffic: Service → DB",
      "description": "Сравнение входящего RPS сервиса и RPS до базы данных.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(requests_total{service=\"product\"}[1m]))",
          "legendFormat": "Service RPS",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(db_requests_total{service=\"product\"}[1m]))",
          "legendFormat": "DB RPS",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Service RPS" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 10 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "DB RPS" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 4,
      "title": "Optimistic Lock Failures/s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(products_db_optimistic_lock_failures_total[1m])",
          "legendFormat": "lock failures/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 100,
      "title": "Outbox",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": true,
      "panels": [
        {
          "id": 101,
          "title": "Pending Records",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 0, "y": 25 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "outbox_records_pending{service=\"product\"}",
              "legendFormat": "",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 100 },
                  { "color": "red", "value": 1000 }
                ]
              }
            }
          },
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "colorMode": "background",
            "graphMode": "area",
            "textMode": "auto"
          }
        },
        {
          "id": 102,
          "title": "Dead Letters",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 6, "y": 25 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "outbox_records_dead_letter{service=\"product\"}",
              "legendFormat": "",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "red", "value": 1 }
                ]
              }
            }
          },
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "colorMode": "background",
            "graphMode": "area",
            "textMode": "auto"
          }
        },
        {
          "id": 103,
          "title": "Outbox Processing Rate",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "sum(rate(outbox_records_processed_total{service=\"product\"}[1m])) by (status)",
              "legendFormat": "{{status}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": { "lineWidth": 2, "fillOpacity": 15, "stacking": { "mode": "normal" } }
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "success" },
                "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
              },
              {
                "matcher": { "id": "byName", "options": "failed" },
                "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
              },
              {
                "matcher": { "id": "byName", "options": "dead_letter" },
                "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
              }
            ]
          },
          "options": {
            "tooltip": { "mode": "multi", "sort": "none" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        }
      ]
    }
  ]
}
