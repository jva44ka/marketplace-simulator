{
  "title": "Cart Service",
  "uid": "marketplace-cart",
  "schemaVersion": 38,
  "version": 7,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "hide": 0,
        "refresh": 1,
        "current": {},
        "includeAll": false,
        "multi": false,
        "options": []
      }
    ]
  },
  "panels": [

    {
      "id": 50,
      "title": "Alerts",
      "description": "Точка появляется когда условие алерта выполняется. Нет точки = всё OK. High Error Rate: ошибки > 5%. High Latency: p90 > 500ms. DB Pool Pressure: avg acquire > 50ms.",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(sum(rate(requests_total{service=\"cart\", code=~\"4..|5..\"}[1m])) / sum(rate(requests_total{service=\"cart\"}[1m])) > 0.05) * 0 + 1",
          "legendFormat": "High Error Rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(histogram_quantile(0.90, sum(rate(request_duration_seconds_bucket{service=\"cart\"}[1m])) by (le)) > 0.5) * 0 + 1",
          "legendFormat": "High Latency p90",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(db_pool_avg_acquire_duration_seconds{service=\"cart\"} > 0.05) * 0 + 1",
          "legendFormat": "DB Pool Pressure",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 2,
          "custom": {
            "drawStyle": "points",
            "pointSize": 14,
            "lineWidth": 0,
            "spanNulls": false,
            "axisPlacement": "hidden"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "High Error Rate" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "High Latency p90" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "DB Pool Pressure" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 1,
      "title": "Overall RPS & p90 Latency",
      "description": "Левая ось — суммарный RPS. Правая ось — p90 время ответа.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(requests_total{service=\"cart\"}[1m]))",
          "legendFormat": "RPS",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.90, sum(rate(request_duration_seconds_bucket{service=\"cart\"}[1m])) by (le))",
          "legendFormat": "p90 Latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p90 Latency" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 2,
      "title": "Error Rate by Method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(requests_total{service=\"cart\", code=~\"4..|5..\"}[1m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 3,
      "title": "Traffic: Service → DB",
      "description": "Сравнение входящего RPS сервиса и RPS до базы данных.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(requests_total{service=\"cart\"}[1m]))",
          "legendFormat": "Service RPS",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(db_requests_total{service=\"cart\"}[1m]))",
          "legendFormat": "DB RPS",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Service RPS" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 10 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "DB RPS" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 200,
      "title": "Database",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "collapsed": true,
      "panels": [
        {
          "id": 201,
          "title": "Connection Pool",
          "description": "Состояние пула соединений: max (лимит), total (открыто), acquired (заняты), idle (свободны).",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "db_pool_max_conns{service=\"cart\"}",
              "legendFormat": "max",
              "refId": "A"
            },
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "db_pool_total_conns{service=\"cart\"}",
              "legendFormat": "total",
              "refId": "B"
            },
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "db_pool_acquired_conns{service=\"cart\"}",
              "legendFormat": "acquired",
              "refId": "C"
            },
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "db_pool_idle_conns{service=\"cart\"}",
              "legendFormat": "idle",
              "refId": "D"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "custom": { "lineWidth": 2, "fillOpacity": 5 }
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "max" },
                "properties": [
                  { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
                  { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 4] } }
                ]
              },
              {
                "matcher": { "id": "byName", "options": "acquired" },
                "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
              },
              {
                "matcher": { "id": "byName", "options": "idle" },
                "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
              }
            ]
          },
          "options": {
            "tooltip": { "mode": "multi", "sort": "desc" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 202,
          "title": "Avg Connection Acquire Duration",
          "description": "Среднее время ожидания соединения из пула за последний интервал сбора. Рост — сигнал перегрузки пула.",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "db_pool_avg_acquire_duration_seconds{service=\"cart\"}",
              "legendFormat": "avg acquire",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "custom": { "lineWidth": 2, "fillOpacity": 10 },
              "color": { "fixedColor": "orange", "mode": "fixed" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 0.01 },
                  { "color": "red", "value": 0.1 }
                ]
              }
            }
          },
          "options": {
            "tooltip": { "mode": "single" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 203,
          "title": "DB Query Duration — p90 by Method",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "histogram_quantile(0.90, sum(rate(db_request_duration_seconds_bucket{service=\"cart\"}[1m])) by (le, method))",
              "legendFormat": "{{method}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "custom": { "lineWidth": 2, "fillOpacity": 5 }
            }
          },
          "options": {
            "tooltip": { "mode": "multi", "sort": "desc" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        }
      ]
    },

    {
      "id": 300,
      "title": "Business",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": true,
      "panels": [
        {
          "id": 301,
          "title": "Orders / s",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 0, "y": 37 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "sum(rate(checkouts_total{service=\"cart\", status=\"success\"}[1m]))",
              "legendFormat": "",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "color": { "fixedColor": "green", "mode": "fixed" },
              "thresholds": {
                "mode": "absolute",
                "steps": [{ "color": "green", "value": null }]
              }
            }
          },
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "colorMode": "background",
            "graphMode": "area",
            "textMode": "auto"
          }
        },
        {
          "id": 302,
          "title": "Checkout Success Rate",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 6, "y": 37 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "100 * sum(rate(checkouts_total{service=\"cart\", status=\"success\"}[5m])) / (sum(rate(checkouts_total{service=\"cart\"}[5m])) > 0)",
              "legendFormat": "",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "orange", "value": 80 },
                  { "color": "green", "value": 95 }
                ]
              }
            }
          },
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "colorMode": "background",
            "graphMode": "area",
            "textMode": "auto"
          }
        },
        {
          "id": 303,
          "title": "Active Carts",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 12, "y": 37 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "active_carts{service=\"cart\"}",
              "legendFormat": "",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "color": { "fixedColor": "blue", "mode": "fixed" },
              "thresholds": {
                "mode": "absolute",
                "steps": [{ "color": "blue", "value": null }]
              }
            }
          },
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "colorMode": "background",
            "graphMode": "area",
            "textMode": "auto"
          }
        },
        {
          "id": 304,
          "title": "Cart Items",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 18, "y": 37 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "cart_items_total{service=\"cart\"}",
              "legendFormat": "",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "color": { "fixedColor": "purple", "mode": "fixed" },
              "thresholds": {
                "mode": "absolute",
                "steps": [{ "color": "purple", "value": null }]
              }
            }
          },
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "colorMode": "background",
            "graphMode": "area",
            "textMode": "auto"
          }
        },
        {
          "id": 305,
          "title": "Checkouts / s — success vs failed",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "sum by (status) (rate(checkouts_total{service=\"cart\"}[1m]))",
              "legendFormat": "{{status}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": { "lineWidth": 2, "fillOpacity": 15, "stacking": { "mode": "normal" } }
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "success" },
                "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
              },
              {
                "matcher": { "id": "byName", "options": "failed" },
                "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
              }
            ]
          },
          "options": {
            "tooltip": { "mode": "multi", "sort": "none" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        },
        {
          "id": 306,
          "title": "Revenue / s",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "sum(rate(checkout_value_total{service=\"cart\"}[1m]))",
              "legendFormat": "revenue/s",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "currencyRUB",
              "custom": { "lineWidth": 2, "fillOpacity": 15 },
              "color": { "fixedColor": "green", "mode": "fixed" }
            }
          },
          "options": {
            "tooltip": { "mode": "single" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        }
      ]
    },

    {
      "id": 100,
      "title": "Outbox",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 },
      "collapsed": true,
      "panels": [
        {
          "id": 101,
          "title": "Pending Records",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 0, "y": 54 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "outbox_records_pending{service=\"cart\"}",
              "legendFormat": "",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 100 },
                  { "color": "red", "value": 1000 }
                ]
              }
            }
          },
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "colorMode": "background",
            "graphMode": "area",
            "textMode": "auto"
          }
        },
        {
          "id": 102,
          "title": "Dead Letters",
          "type": "stat",
          "gridPos": { "h": 4, "w": 6, "x": 6, "y": 54 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "outbox_records_dead_letter{service=\"cart\"}",
              "legendFormat": "",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "red", "value": 1 }
                ]
              }
            }
          },
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"] },
            "colorMode": "background",
            "graphMode": "area",
            "textMode": "auto"
          }
        },
        {
          "id": 103,
          "title": "Outbox Processing Rate",
          "type": "timeseries",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 54 },
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${datasource}" },
              "expr": "sum(rate(outbox_records_processed_total{service=\"cart\"}[1m])) by (status)",
              "legendFormat": "{{status}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": { "lineWidth": 2, "fillOpacity": 15, "stacking": { "mode": "normal" } }
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "success" },
                "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
              },
              {
                "matcher": { "id": "byName", "options": "failed" },
                "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
              },
              {
                "matcher": { "id": "byName", "options": "dead_letter" },
                "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
              }
            ]
          },
          "options": {
            "tooltip": { "mode": "multi", "sort": "none" },
            "legend": { "displayMode": "list", "placement": "bottom" }
          }
        }
      ]
    }

  ]
}
