      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 13,
      "title": "Products — Success Rate %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(outbox_records_processed_total{service="product"}{status=\"success\"}[5m])) / sum(rate(outbox_records_processed_total{service="product"}[5m])) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdMarkers": true
      }
    },
    {
      "id": 14,
      "title": "Cart — Success Rate %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(outbox_records_processed_total{service="cart"}{status=\"success\"}[5m])) / sum(rate(outbox_records_processed_total{service="cart"}[5m])) * 100",
